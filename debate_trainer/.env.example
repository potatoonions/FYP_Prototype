# AI Debate Trainer Environment Configuration
# Copy this file to .env and fill in your values

# Django Configuration
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# AI Provider Configuration
# Choose provider: "openai" or "google"
AI_MODEL_PROVIDER=google

# OpenAI Settings (if using OpenAI)
AI_API_KEY=your-openai-api-key-here
AI_MODEL_NAME=gpt-4o-mini

# Google Gemini Settings (if using Google)
# AI_API_KEY=your-google-gemini-api-key-here
# AI_MODEL_NAME=gemini-1.5-flash

# Optional: Enable API tracing for debugging
AI_TRACE=False
